{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "plugins": ["prettier-plugin-tailwindcss"],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "asNeeded",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "experimentalSortImports": true,
  "tailwindFunctions": ["clsx", "cn", "tw", "twMerge", "cva"]
}
